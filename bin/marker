#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent))

from marker import core


def _require_sourced() -> None:
    if not os.getenv("MARKER_DATA_HOME"):
        sys.exit("Please source the marker file in your shell's rc file first.")


def _parse_and_run() -> None:
    parser = argparse.ArgumentParser(
        description="Marker: bookmark and retrieve shell commands"
    )
    sub = parser.add_subparsers(title="commands", dest="cmd")

    p_mark = sub.add_parser("mark", help="bookmark a command")
    p_mark.add_argument("--command", type=str)
    p_mark.add_argument("--alias", type=str)

    p_get = sub.add_parser("get", help="fuzzy-search bookmarks")
    p_get.add_argument("--search", type=str)
    p_get.add_argument("--stdout", type=str, help="write result to this file instead of stdout")

    p_rm = sub.add_parser("remove", help="remove a bookmarked command")
    p_rm.add_argument("--search", type=str)

    p_update = sub.add_parser("update", help="update tldr-pages, navi, and optionally cheat.sh")
    p_update.add_argument("--cheatsh", nargs="+", metavar="TOPIC")
    p_update.add_argument("--history", action="store_true", help="also import shell history")

    p_complete = sub.add_parser("complete", help="pick a value from a shell command's output")
    p_complete.add_argument("--command", type=str, required=True, help="shell command to run")
    p_complete.add_argument("--stdout", type=str, help="write result to this file")

    p_ph = sub.add_parser("placeholder", help="placeholder utilities for shell integration")
    ph_sub = p_ph.add_subparsers(title="actions", dest="ph_action")

    ph_find = ph_sub.add_parser("find", help="find first placeholder; prints '<offset> <text>'")
    ph_find.add_argument("text", type=str)

    ph_dynCmd = ph_sub.add_parser("dyn-cmd", help="print dynamic command from a placeholder")
    ph_dynCmd.add_argument("placeholder", type=str)

    ph_replace = ph_sub.add_parser("replace", help="replace placeholder; prints '<cursor> <new_text>'")
    ph_replace.add_argument("text", type=str)
    ph_replace.add_argument("placeholder", type=str)
    ph_replace.add_argument("value", type=str)

    args = parser.parse_args()

    if args.cmd == "mark":
        core.mark_command(args.command, args.alias)
    elif args.cmd == "get":
        result = core.get_selected_command_or_input(args.search)
        if args.stdout:
            Path(args.stdout).write_text(result + "\n" if result else "")
        else:
            print(result)
    elif args.cmd == "remove":
        core.remove_command(args.search)
    elif args.cmd == "update":
        core.update_cache(
            cheatsh_topics=getattr(args, "cheatsh", None),
            history=args.history,
        )
    elif args.cmd == "complete":
        result = core.complete_placeholder(args.command)
        if args.stdout:
            Path(args.stdout).write_text((result or "") + "\n")
        else:
            print(result or "")
    elif args.cmd == "placeholder":
        from marker.placeholder import dynamic_command, find_first, replace as ph_replace
        if args.ph_action == "find":
            found = find_first(args.text)
            if found:
                ph_text, offset = found
                print(f"{offset} {ph_text}")
        elif args.ph_action == "dyn-cmd":
            cmd = dynamic_command(args.placeholder)
            if cmd:
                print(cmd)
        elif args.ph_action == "replace":
            new_text, cursor = ph_replace(args.text, args.placeholder, args.value)
            print(f"{cursor}")
            print(new_text)
        else:
            p_ph.print_help()
    else:
        parser.print_help()


if __name__ == "__main__":
    _require_sourced()
    try:
        _parse_and_run()
    except KeyboardInterrupt:
        sys.exit(0)
